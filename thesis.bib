  file = {/Users/lukaskratzel/Zotero/storage/PUGWCTMZ/Frankford et al. - 2024 - AI-Tutoring in Software Engineering Education.pdf;/Users/lukaskratzel/Zotero/storage/TEUD2I8S/Frankford et al. - 2024 - AI-Tutoring in Software Engineering Education.pdf}
}

